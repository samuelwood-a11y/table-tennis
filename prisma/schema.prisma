datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Group {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  sport       String   @default("TABLE_TENNIS")
  imageUrl    String?
  clubName    String?
  createdAt   DateTime @default(now())
  adminEmail            String?
  previousCode          String?
  previousCodeExpiresAt DateTime?

  players        Player[]
  teams          Team[]
  matches        Match[]
  leagues        League[]
  tournaments    Tournament[]
  doublesTeams   DoublesTeam[]
  recoveryTokens RecoveryToken[]
}

model Player {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  nickname    String?
  notes       String?
  imageUrl    String?
  avatarColor String   @default("#6366f1")
  emoji       String?
  isArchived  Boolean  @default(false)
  archivedAt  DateTime?
  createdAt   DateTime @default(now())

  group             Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  singlesMatchesP1  Match[]             @relation("Player1")
  singlesMatchesP2  Match[]             @relation("Player2")
  refereedMatches   Match[]             @relation("MatchReferee")
  doublesTeams      DoublesTeamPlayer[]
  teamMemberships   TeamPlayer[]
  leagueEntries     LeaguePlayer[]
  tournamentEntries TournamentEntry[]
  payments          PlayerPayment[]
}

model Team {
  id             String    @id @default(cuid())
  groupId        String
  name           String
  primaryColor   String    @default("#6366f1")
  secondaryColor String?
  imageUrl       String?
  isArchived     Boolean   @default(false)
  archivedAt     DateTime?
  createdAt      DateTime  @default(now())

  group              Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  players            TeamPlayer[]
  leagueEntries      LeagueTeam[]
  tournamentEntries  TournamentTeamEntry[]
  matchesAsHome      Match[]                @relation("MatchHomeTeam")
  matchesAsAway      Match[]                @relation("MatchAwayTeam")
}

model TeamPlayer {
  teamId    String
  playerId  String
  isCaptain Boolean @default(false)
  position  String?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([teamId, playerId])
}

model DoublesTeam {
  id      String @id @default(cuid())
  groupId String

  group   Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  players DoublesTeamPlayer[]

  matchesAsTeam1 Match[] @relation("Team1")
  matchesAsTeam2 Match[] @relation("Team2")
}

model DoublesTeamPlayer {
  teamId   String
  playerId String

  team   DoublesTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([teamId, playerId])
}

model Match {
  id              String    @id @default(cuid())
  groupId         String
  type            String    @default("SINGLES")
  status          String    @default("PENDING")
  playedAt        DateTime  @default(now())
  scheduledAt     DateTime?
  venue           String?
  leagueId        String?
  tournamentId    String?
  bracketRound    Int?
  bracketPosition Int?
  refereeId       String?

  group      Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  league     League?     @relation(fields: [leagueId], references: [id])
  tournament Tournament? @relation(fields: [tournamentId], references: [id])
  referee    Player?     @relation("MatchReferee", fields: [refereeId], references: [id])

  player1Id String?
  player2Id String?
  player1   Player? @relation("Player1", fields: [player1Id], references: [id])
  player2   Player? @relation("Player2", fields: [player2Id], references: [id])

  team1Id String?
  team2Id String?
  team1   DoublesTeam? @relation("Team1", fields: [team1Id], references: [id])
  team2   DoublesTeam? @relation("Team2", fields: [team2Id], references: [id])

  homeTeamId String?
  awayTeamId String?
  homeTeam   Team? @relation("MatchHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team? @relation("MatchAwayTeam", fields: [awayTeamId], references: [id])

  sets Set[]
}

model Set {
  id        String @id @default(cuid())
  matchId   String
  setNumber Int
  score1    Int    @default(0)
  score2    Int    @default(0)

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model League {
  id           String   @id @default(cuid())
  groupId      String
  name         String
  status       String   @default("ACTIVE")
  format       String   @default("SINGLES")
  entryFee     Float?
  currency     String   @default("GBP")
  expectedPot  Float?
  isArchived   Boolean  @default(false)
  pointsConfig String?
  teamSize     Int?
  createdAt    DateTime @default(now())

  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  players    LeaguePlayer[]
  teams      LeagueTeam[]
  matches    Match[]
  prizeRows  PrizePayoutRow[]
  payments   PlayerPayment[]
}

model LeaguePlayer {
  id       String @id @default(cuid())
  leagueId String
  playerId String

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([leagueId, playerId])
}

model LeagueTeam {
  id       String @id @default(cuid())
  leagueId String
  teamId   String

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([leagueId, teamId])
}

model Tournament {
  id          String   @id @default(cuid())
  groupId     String
  name        String
  type        String   @default("SINGLES")
  format      String   @default("SINGLES")
  status      String   @default("ACTIVE")
  entryFee    Float?
  currency    String   @default("GBP")
  expectedPot Float?
  isArchived  Boolean  @default(false)
  teamSize    Int?
  createdAt   DateTime @default(now())

  group    Group                @relation(fields: [groupId], references: [id], onDelete: Cascade)
  entries  TournamentEntry[]
  teamEntries TournamentTeamEntry[]
  matches  Match[]
  prizeRows PrizePayoutRow[]
  payments  PlayerPayment[]
}

model TournamentEntry {
  id           String @id @default(cuid())
  tournamentId String
  playerId     String
  seed         Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
}

model TournamentTeamEntry {
  id           String @id @default(cuid())
  tournamentId String
  teamId       String
  seed         Int?

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
}

model RecoveryToken {
  id        String   @id @default(cuid())
  groupId   String
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model PlayerPayment {
  id           String    @id @default(cuid())
  playerId     String
  leagueId     String?
  tournamentId String?
  status       String    @default("UNPAID")
  amountDue    Float     @default(0)
  amountPaid   Float     @default(0)
  paidAt       DateTime?
  notes        String?

  player     Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  league     League?     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}

model PrizePayoutRow {
  id           String  @id @default(cuid())
  leagueId     String?
  tournamentId String?
  position     Int
  label        String
  amount       Float?
  percentage   Float?

  league     League?     @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  tournament Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
}
